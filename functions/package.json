{
  "name": "digital-passport-functions",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions for Digital Passport",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@google/generative-ai": "^0.15.0",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^7.1.0",
    "googleapis": "^140.0.0",
    "mupdf": "^1.27.0",
    "pdf2pic": "^3.2.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  },
  "private": true
}
